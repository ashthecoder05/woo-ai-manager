# ─────────────────────────────────────────────────────────────
# Blocko Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Azure OpenAI (required)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Blockonomics (required for Bitcoin payments)
BLOCKONOMICS_API_KEY=your_blockonomics_api_key_here
BLOCKONOMICS_WEBHOOK_SECRET=generate_a_random_32char_string_here

# Merchant info
MERCHANT_URL=https://yourdomain.com
MERCHANT_NAME=Your Store Name
MERCHANT_DESCRIPTION=Accept Bitcoin payments
SUPPORT_EMAIL=support@yourdomain.com

# Security — set to your production domain(s), comma-separated
# Leave blank for local development (allows all origins)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ENVIRONMENT=production

# CSRF secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
CSRF_SECRET=0e32e309e444dadd7846876c89c3472c73d9a9a28332914be401ac215c49750d

# Trusted reverse proxy IPs (comma-separated) — only these can set X-Forwarded-For
TRUSTED_PROXIES=127.0.0.1,::1

# Google OAuth (strongly recommended for production)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID → Web application
# Add your domain to Authorized JavaScript origins
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Telegram bot (optional — get from @BotFather on Telegram)
# If set, the bot auto-starts when the server boots.
# You can also enter the token via the dashboard UI.
TELEGRAM_BOT_TOKEN=
